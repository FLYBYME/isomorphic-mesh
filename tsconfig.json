{
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "WebWorker"],
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "isomorphic-core": ["../isomorphic-core/src/index"],
      "isomorphic-registry": ["../isomorphic-registry/src/index"],
      "raft-consensus": ["../raft-consensus/src/index"]
    }
  },
  "include": ["src/**/*"]
}
